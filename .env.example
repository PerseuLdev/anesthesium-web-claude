# Google Gemini API key — required for AI clinical analysis
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# OpenRouter API key — used as fallback when Gemini is unavailable
# Get yours at: https://openrouter.ai/keys
EXPO_PUBLIC_OPENROUTER_KEY="YOUR_OPENROUTER_KEY"

# OpenRouter model to use as fallback (default: z-ai/glm-4.5-air:free)
EXPO_PUBLIC_OPENROUTER_MODEL="z-ai/glm-4.5-air:free"
